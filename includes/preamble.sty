% Teoremas e ambientes


\definecolor{defback}{HTML}{FFFEFA}
\definecolor{defline}{HTML}{8A7A5E}

\definecolor{resultback}{HTML}{F8FBFF}
\definecolor{resultline}{HTML}{2F5368}
\definecolor{knowMoreBack}{HTML}{FDF8F5}
\definecolor{knowMoreLine}{HTML}{8A7A5E}

\definecolor{exampleline}{HTML}{D8D4C8}

\newlength{\bookparindent}
\setlength{\bookparindent}{\parindent}

\newlength{\bookparskip}
\setlength{\bookparskip}{\parskip}

\tcbset{
    exampleStyle/.style={
      shield externalize,
      enhanced,
      breakable,
      blanker,
      borderline south={0.35pt}{0pt}{exampleline},
      left=0pt,
      right=0pt,
      top=7pt,
      bottom=12pt,
      before skip=10pt,
      after skip=10pt,
      before upper={%
        \setlength{\parindent}{\bookparindent}%
        \setlength{\parskip}{\bookparskip}%
      },
    }
}
\tcolorboxenvironment{example}{
    exampleStyle
}
\tcbset{
    definitionStyle/.style={
      enhanced,
      breakable,
      lines before break=3,
      colback=defback,
      colframe=defline,
      boxrule=0.15pt,
      leftrule=1.6pt,
      arc=1.5pt,
      left=5pt,
      right=5pt,
      top=6pt,
      bottom=6pt,
      before skip=10pt,
      after skip=10pt,
      toprule at break=0pt,
      bottomrule at break=0pt,
      before upper={%
        \setlength{\parindent}{\bookparindent}%
        \setlength{\parskip}{\bookparskip}%
      },
    },
    knowMoreStyle/.style={
      enhanced,
      breakable,
      lines before break=3,
      colback=knowMoreBack,
      colframe=knowMoreLine,
      boxrule=0.15pt,
      leftrule=1.6pt,
      arc=1.5pt,
      left=5pt,
      right=5pt,
      top=6pt,
      bottom=6pt,
      before skip=10pt,
      after skip=10pt,
      toprule at break=0pt,
      bottomrule at break=0pt,
      before upper={%
        \setlength{\parindent}{\bookparindent}%
        \setlength{\parskip}{\bookparskip}%
      },
    },
  resultStyle/.style={
    shield externalize,
    enhanced,
    breakable,
    colback=resultback,
    colframe=resultline,
    boxrule=0.15pt,
    leftrule=1.8pt,
    arc=1.5pt,
    left=5pt,
    right=5pt,
    top=6pt,
    bottom=6pt,
    before skip=10pt,
    after skip=10pt,
    toprule at break=0pt,
    bottomrule at break=0pt,
    before upper={%
      \setlength{\parindent}{\bookparindent}%
      \setlength{\parskip}{\bookparskip}%
    },
    }
}

\tcolorboxenvironment{metadefinition}{
    definitionStyle
}
\tcolorboxenvironment{definition}{
